# ==========================================
# CANDAS BACKEND - ENV EJEMPLO UNICO
# ==========================================
# Copia este archivo a .env y ajusta valores.
#
# FORMAS DE USO:
# 1) LOCAL:
#    SPRING_PROFILES_ACTIVE=dev
#    SERVER_ADDRESS=127.0.0.1
#    CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# 2) LAN (móvil/otro PC):
#    SPRING_PROFILES_ACTIVE=lan
#    SERVER_ADDRESS=0.0.0.0
#    CORS_ALLOWED_ORIGINS=http://<TU-IP-LAN>:5173
#    (o CORS_ALLOWED_ORIGINS=* para cualquier origen en red local)
#
# 3) PRODUCCION — ver docs/RAILWAY_ENV.md
#    SPRING_PROFILES_ACTIVE=prod
#    CORS_ALLOWED_ORIGINS=https://<dominio-del-frontend>
#    (solo el origen de la SPA en el navegador, no la URL del API)

SPRING_PROFILES_ACTIVE=dev
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8187

DB_URL=jdbc:postgresql://db-r4nd0m.local:5544/candas_demo_9x7
DB_USERNAME=user_9f2k
DB_PASSWORD=pass_k3n8_qp1

# Genere un secreto aleatorio de al menos 32 bytes, por ejemplo:
# openssl rand -base64 48
JWT_SECRET=reemplazar-con-un-secreto-aleatorio-de-al-menos-32-bytes
JWT_EXPIRATION=79200000
BCRYPT_STRENGTH=12
PUBLIC_REGISTRATION_ENABLED=true

CREATE_DEFAULT_ADMIN=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@candas.com
ADMIN_FULL_NAME=Administrador del Sistema

# Recomendado (lista explícita separada por comas)
# Orígenes del frontend (obligatorio para CORS). Separar por comas.
CORS_ALLOWED_ORIGINS=http://localhost:5279,http://127.0.0.1:5279
