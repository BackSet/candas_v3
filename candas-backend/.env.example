# ==========================================
# CANDAS BACKEND - ENV EJEMPLO UNICO
# ==========================================
# Copia este archivo a .env y ajusta valores.
#
# FORMAS DE USO:
# 1) LOCAL:
#    SPRING_PROFILES_ACTIVE=dev
#    SERVER_ADDRESS=127.0.0.1
#    CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# 2) LAN (móvil/otro PC):
#    SPRING_PROFILES_ACTIVE=lan
#    SERVER_ADDRESS=0.0.0.0
#    CORS_ALLOWED_ORIGINS=http://<TU-IP-LAN>:5173
#    (opcional) CORS_ALLOWED_ORIGIN_PATTERNS=*
#
# 3) PRODUCCION:
#    SPRING_PROFILES_ACTIVE=prod
#    SERVER_ADDRESS=0.0.0.0
#    CORS_ALLOWED_ORIGINS=https://tu-frontend.com

SPRING_PROFILES_ACTIVE=dev
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/candas_v3
DB_USERNAME=postgres
DB_PASSWORD=postgres

JWT_SECRET=replace-with-strong-secret-min-32-chars
JWT_EXPIRATION=86400000

# Recomendado (lista explícita separada por comas)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Compatibilidad (usar solo si necesitas patrón global)
# CORS_ALLOWED_ORIGIN_PATTERNS=*
