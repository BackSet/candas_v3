# Desarrollo local (`npm run dev`). Copiar a .env.development
#
# Solo el valor "lan" tiene efecto especial: Vite escucha en 0.0.0.0 y, si no defines
# VITE_API_BASE_URL, el cliente usa http://<hostname-de-la-página>:8080
# VITE_NETWORK_MODE=lan

VITE_API_BASE_URL=http://localhost:8080
VITE_PORT=5173
