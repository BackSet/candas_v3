# ==========================================
# CANDAS FRONTEND - ENV EJEMPLO UNICO
# ==========================================
# Copia este archivo a:
# - .env.development para npm run dev
# - .env.production para npm run build local
# O define las mismas variables en CI / Railway.
#
# FORMAS DE USO:
# 1) LOCAL:
#    VITE_API_BASE_URL=http://localhost:8080
#    VITE_PORT=5173
#
# 2) LAN (móvil/otro PC):
#    VITE_NETWORK_MODE=lan
#    VITE_API_BASE_URL=http://<IP-LAN-BACKEND>:8080
#    VITE_PORT=5173
#
# 3) PRODUCCION (Railway / bymerge.org):
#    VITE_API_BASE_URL=https://api-candas.bymerge.org
#    o VITE_API_BASE_URL=https://${{candas-backend.RAILWAY_PUBLIC_DOMAIN}}
#    (no usar VITE_API_URL — otro proyecto)

# URL pública del frontend (SEO, Open Graph al compartir enlaces; sin barra final)
# VITE_APP_URL=https://candas.bymerge.org

# API base (URL completa del backend)
VITE_API_BASE_URL=https://api-demo-7k9m.candas.test

# Puerto del dev server
VITE_PORT=5279

# Modo de red del dev server (vacío o "lan")
VITE_NETWORK_MODE=lan

# Hosts adicionales permitidos por Vite, separados por comas. Déjelo vacío en local.
VITE_ALLOWED_HOSTS=
