# Plantilla para build de producción (Railway, CI, docker build).
# Solo esta variable define el backend; sin puerto implícito en el código (URL completa).
# En Railway: misma variable en el servicio frontend, marcada para Build.
# Imagen Docker: Nginx sirve el SPA; PORT en runtime (Railway) debe coincidir con el target del dominio (por defecto 80).
VITE_API_BASE_URL=https://TU_BACKEND.up.railway.app
