# ==========================================
# CANDAS FRONTEND - ENV EJEMPLO UNICO
# ==========================================
# Copia este archivo a:
# - .env.development para npm run dev
# - .env.production para npm run build local
# O define las mismas variables en CI / Railway.
#
# FORMAS DE USO:
# 1) LOCAL:
#    VITE_API_BASE_URL=http://localhost:8080
#    VITE_PORT=5173
#
# 2) LAN (móvil/otro PC):
#    VITE_NETWORK_MODE=lan
#    VITE_API_BASE_URL=http://<IP-LAN-BACKEND>:8080
#    VITE_PORT=5173
#
# 3) PRODUCCION:
#    VITE_API_BASE_URL=https://tu-backend.up.railway.app
#    (VITE_NETWORK_MODE normalmente vacío en producción)

# API base (URL completa del backend)
VITE_API_BASE_URL=http://localhost:8080

# Puerto del dev server
VITE_PORT=5173

# Modo de red del dev server (vacío o "lan")
# VITE_NETWORK_MODE=lan
